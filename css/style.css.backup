    60|/* Leadership Page Styles */
    61|.leadership-section {
    62|    padding: 80px 0;
    63|    background-color: #f8f9fa;
    64|}
    65|
    66|.leadership-profile {
    67|    display: flex;
    68|    flex-wrap: wrap;
    69|    gap: 40px;
    70|    background: white;
    71|    border-radius: 10px;
    72|    padding: 40px;
    73|    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    74|}
    75|
    76|.profile-image {
    77|    flex: 0 0 300px;
    78|}
    79|
    80|.profile-image img {
    81|    width: 100%;
    82|    height: auto;
    83|    border-radius: 10px;
    84|    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
    85|}
    86|
    87|.profile-content {
    88|    flex: 1;
    89|    min-width: 300px;
    90|}
    91|
    92|.profile-content h2 {
    93|    color: #1a365d;
    94|    margin-bottom: 5px;
    95|}
    96|
    97|.profile-content h3 {
    98|    color: #4a5568;
    99|    font-weight: 500;
   100|    margin-bottom: 20px;
   101|    font-size: 1.3rem;
   102|}
   103|
   104|.profile-bio {
   105|    margin-bottom: 30px;
   106|    line-height: 1.8;
   107|}
