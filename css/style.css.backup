   312|   128|
   313|   129|/* Hero Section */
   314|   130|.hero {
   315|   131|    background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), 
   316|   132|                url('../images/hero-bg.jpg') center/cover no-repeat;
   317|   133|    color: white;
   318|   134|    padding: 6rem 0;
   319|   135|    text-align: center;
   320|   136|}
   321|   137|
   322|   138|.hero-content h2 {
