/* Leadership Preview Styles */
.leadership-preview {
    margin: 40px 0;
}

.leadership-card {
    display: flex;
    flex-wrap: wrap;
    gap: 30px;
    background: white;
    border-radius: 10px;
    padding: 30px;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    margin-bottom: 20px;
}

.leadership-image {
    flex: 0 0 200px;
}

.leadership-image img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
}

.leadership-info {
    flex: 1;
    min-width: 300px;
}

.leadership-info h3 {
    color: #1a365d;
    margin-bottom: 5px;
}

.position {
    color: #4a5568;
    font-weight: 600;
    margin-bottom: 15px;
    font-size: 1.1rem;
}

.bio {
    line-height: 1.7;
    margin-bottom: 20px;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .leadership-card {
        flex-direction: column;
        text-align: center;
    }
    
    .leadership-image {
        flex: 0 0 auto;
        margin: 0 auto;
        max-width: 200px;
    }
}
